NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Notion 連携（任意） ----
# 設定しない場合は Notion 同期はスキップされます
# セットアップ手順:
#   1. https://www.notion.so/my-integrations でインテグレーションを作成
#   2. 下記 3 つの DB を Notion で作成し、インテグレーションと共有
#   3. DB の URL から ID をコピー（https://notion.so/xxx?v=yyy の xxx 部分）

NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB①: 思考ログ
# 必要なプロパティ:
#   出来事（Title）/ モード（Select）/ 気分スコア（Number）/ 日付（Date）
#   自動思考（Text）/ 感情タイプ（Multi-select）/ 感情レベル（Number）
#   事実（Text）/ 別の解釈（Text）/ 行動計画（Text）/ 感情テキスト（Text）
#   頭に浮かんだこと（Text）/ 事実（2col）（Text）/ 解釈（Text）
NOTION_CBT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB②: 行動ログ
# 必要なプロパティ:
#   状況（Title）/ 日付（Date）/ 感情（Text）/ とった行動（Text）
#   10分ルール（Checkbox）/ 結果（Select: 良かった/微妙/悪化）/ 学び（Text）
NOTION_ACTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB③: 習慣トラッカー
# 必要なプロパティ:
#   タイトル（Title）/ 日付（Date）
#   思考ログ書いた（Checkbox）/ 10分ルール実行（Checkbox）
#   主体的な発言した（Checkbox）/ NGワード使わなかった（Checkbox）/ アウトプットした（Checkbox）
# Formula プロパティ（任意・スコア化）:
#   スコア: toNumber(prop("思考ログ書いた")) + toNumber(prop("10分ルール実行")) + toNumber(prop("主体的な発言した")) + toNumber(prop("NGワード使わなかった")) + toNumber(prop("アウトプットした"))
NOTION_HABIT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
